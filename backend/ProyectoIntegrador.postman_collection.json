{
  "info": {
    "name": "CMS Multipaís - API (Top 10)",
    "description": "Colección reducida con los 10 endpoints más importantes para probar la API del CMS Multipaís.\n\nAutenticación: Usar Login para obtener token, se guarda automáticamente.\nRoles: superadmin, admin_pais, editor.\n\nEndpoints incluidos:\n1. API Status\n2. Login\n3. Register\n4. Get My Profile\n5. List Users\n6. Get Public News by Country\n7. List All News (admin)\n8. Create News\n9. Create Public Testimonial\n10. Create Public Contact Request",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "API Status & Docs",
      "item": [
        {
          "name": "API Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Mensaje de funcionamiento', () => {",
                  "    pm.expect(pm.response.json().message).to.include('funcionando');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api",
              "host": ["{{base_url}}"],
              "path": ["api"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - éxito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body tiene token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json).to.have.property('refreshToken');",
                  "    pm.expect(json).to.have.property('user');",
                  "    pm.expect(json.user).to.have.property('username');",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Body tiene user registrado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json).to.have.property('user');",
                  "    pm.expect(json.user).to.have.property('username');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test_{{$randomInt}}\",\n  \"password\": \"123456\",\n  \"nombre\": \"Test\",\n  \"apellido\": \"Postman\",\n  \"email\": \"test_{{$randomInt}}@test.com\",\n  \"rol_id\": 2,\n  \"pais_id\": 1,\n  \"pregunta_seguridad\": \"¿Color favorito?\",\n  \"respuesta_seguridad\": \"azul\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Get My Profile (auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body tiene datos del usuario', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data).to.have.property('username');",
                  "    pm.expect(json.data).to.have.property('rol');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body es un array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            }
          }
        }
      ]
    },
    {
      "name": "News",
      "item": [
        {
          "name": "Get Public News by Country",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body es un array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/news/public/argentina",
              "host": ["{{base_url}}"],
              "path": ["api", "news", "public", "argentina"]
            }
          }
        },
        {
          "name": "List All News (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body es un array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/news",
              "host": ["{{base_url}}"],
              "path": ["api", "news"]
            }
          }
        },
        {
          "name": "Create News",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Noticia creada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data.titulo).to.include('Postman');",
                  "    pm.collectionVariables.set('testNewsId', json.data.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Noticia Postman {{$randomInt}}\",\n  \"resumen\": \"Resumen de la noticia de prueba\",\n  \"contenido\": \"Contenido completo generado desde Postman\",\n  \"pais_id\": 1,\n  \"categoria_id\": 1,\n  \"estado\": \"borrador\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/news",
              "host": ["{{base_url}}"],
              "path": ["api", "news"]
            }
          }
        }
      ]
    },
    {
      "name": "Testimonials",
      "item": [
        {
          "name": "Create Public Testimonial",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Testimonio creado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data.estado).to.equal('borrador');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Pérez\",\n  \"cargo\": \"CEO\",\n  \"contenido\": \"Excelente servicio, muy recomendado desde Postman.\",\n  \"pais_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/testimonials/public",
              "host": ["{{base_url}}"],
              "path": ["api", "testimonials", "public"]
            }
          }
        }
      ]
    },
    {
      "name": "Contact Requests",
      "item": [
        {
          "name": "Create Public Request - éxito",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Solicitud creada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.collectionVariables.set('testRequestId', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pais_id\": 1,\n  \"nombre\": \"Carlos López\",\n  \"correo\": \"carlos@ejemplo.com\",\n  \"telefono\": \"123456789\",\n  \"finalidad\": \"Servicio\",\n  \"mensaje\": \"Quiero más información\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/contact-requests/public",
              "host": ["{{base_url}}"],
              "path": ["api", "contact-requests", "public"]
            }
          }
        }
      ]
    }
  ],
